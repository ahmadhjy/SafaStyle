# Copy to .env and fill in real values. .env is gitignored.
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (set on droplet)
# DEBUG=false
# ALLOWED_HOSTS=safastyle.com,www.safastyle.com
# CSRF_TRUSTED_ORIGINS=https://safastyle.com,https://www.safastyle.com
# DB_ENGINE=postgresql
# DB_NAME=safastyle
# DB_USER=safastyle
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=info@safastyle.com
EMAIL_HOST_PASSWORD=your-mailbox-password

DEFAULT_FROM_EMAIL=Safa Style <info@safastyle.com>
ORDER_NOTIFICATION_EMAILS=info@safastyle.com,sales@safastyle.com
CONTACT_EMAIL=info@safastyle.com

# Production site URL (used for SEO / emails)
SITE_URL=https://safastyle.com

# WooCommerce import — use your Bluehost temporary URL until DNS fully moves off WordPress
# Find it in Bluehost → WordPress → Manage → Settings → Site URL / Temporary URL
# WOO_BASE_URL=https://your-temp-url.mybluehost.me
# WOO_CONSUMER_KEY=ck_...
# WOO_CONSUMER_SECRET=cs_...
